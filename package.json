{
	"name": "smartwater-infoportal",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "npm run install-lib && next dev --turbopack",
		"dev-host": "next dev --turbopack --hostname 0.0.0.0",
		"build": "npm run install-lib && next build",
		"start": "npm run install-lib && next start",
		"lint": "eslint --quiet",
		"install-lib": "npm install github:technologiestiftung/berlin-ui-library",
		"prepare": "husky",
		"reset": "rm -rf node_modules .next package-lock.json && npm install && npm run dev",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:one": "jest searchAddresses",
		"m:staging": "git fetch origin staging && git merge origin/staging"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@fortawesome/fontawesome-svg-core": "^7.0.0",
		"@fortawesome/free-solid-svg-icons": "^7.0.0",
		"@fortawesome/react-fontawesome": "^3.0.0",
		"@radix-ui/react-checkbox": "^1.3.2",
		"@socialgouv/matomo-next": "^1.11.0",
		"@sparticuz/chromium": "^143.0.4",
		"@sparticuz/chromium-min": "^143.0.4",
		"@tailwindcss/postcss": "^4",
		"@turf/turf": "^7.3.4",
		"berlin-ui-library": "github:technologiestiftung/berlin-ui-library",
		"dotenv": "^17.2.1",
		"jspdf": "^4.1.0",
		"lucide-react": "^0.577.0",
		"next": "16.2.3",
		"next-intl": "^4.1.0",
		"ol": "^10.6.1",
		"ol-mapbox-style": "^13.0.1",
		"proj4": "^2.19.10",
		"puppeteer": "^24.37.2",
		"puppeteer-core": "^24.37.2",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"react-error-boundary": "^6.0.0",
		"shapefile": "^0.6.6",
		"tailwindcss": "^4",
		"zustand": "^5.0.7"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.1.0",
		"@commitlint/config-conventional": "^20.0.0",
		"@technologiestiftung/prettier-config": "1.0.0",
		"@types/jest": "^30.0.0",
		"@types/node": "^24.0.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"eslint": "^9",
		"eslint-config-next": "16.2.3",
		"eslint-plugin-jest": "^29.0.1",
		"husky": "^9.1.7",
		"jest": "^30.0.5",
		"prettier": "^3.5.3",
		"prettier-plugin-tailwindcss": "^0.7.0",
		"tailwindcss": "^4",
		"ts-jest": "^29.4.1",
		"typescript": "^5"
	},
	"optionalDependencies": {
		"@tailwindcss/oxide-linux-x64-gnu": "^4.1.11",
		"lightningcss-linux-x64-gnu": "^1.30.1"
	}
}
